# Telegram
TELEGRAM_BOT_TOKEN=
CHAT_IDS=123456789,987654321      # comma-separated, get from /start handler

# Polling
POLL_SECONDS=300                   # default 5 minutes; minimum recommended: 60

# Staleness gate
MAX_QUOTE_AGE_S=120                # suppress/flag alerts if quote older than this

# Ticker map (update after running probe.py if XAU ticker differs)
TICKER_PAXG=PAXG
TICKER_XAUT=XAUT
TICKER_XAU=XAU                    # may need to change to GOLD or XAUUSD

# XAU source: variational | external
XAU_SOURCE=variational

# Only needed if XAU_SOURCE=external
GOLD_API_KEY=

# Thresholds (absolute USD)
PAXG_XAUT_HIGH=20
PAXG_XAUT_LOW=10
XAU_XAUT_HIGH=17
XAU_XAUT_LOW=7

# Hysteresis: spread must cross back by this amount before re-arming
RESET_BUFFER=2

# Cooldown: minimum seconds between alerts for the same condition regardless of hysteresis
COOLDOWN_S=900
